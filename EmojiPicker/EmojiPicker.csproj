<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    
    <!-- Application Info -->
    <AssemblyTitle>Windows 10 Emoji Picker</AssemblyTitle>
    <AssemblyDescription>Lightweight Windows 10 style emoji picker for Windows 11</AssemblyDescription>
    <AssemblyProduct>EmojiPicker</AssemblyProduct>
    <AssemblyCopyright>Copyright © Platima 2025</AssemblyCopyright>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0.0</FileVersion>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="Fonts\seguiemj.ttf" />
  </ItemGroup>

</Project>