<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark theme: approximates the Windows 10 dark emoji panel -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#2B2B2B"/>
    <SolidColorBrush x:Key="WindowBorderBrush" Color="#1D1D1D"/>
    <SolidColorBrush x:Key="TabStripBackgroundBrush" Color="#333333"/>
    <SolidColorBrush x:Key="HeaderForegroundBrush" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#3D3D3D"/>
    <SolidColorBrush x:Key="SearchBackgroundBrush" Color="#333333"/>
    <SolidColorBrush x:Key="SearchForegroundBrush" Color="#EEEEEE"/>
    <SolidColorBrush x:Key="SearchBorderBrush" Color="#555555"/>
    <SolidColorBrush x:Key="WatermarkForegroundBrush" Color="#888888"/>
    <SolidColorBrush x:Key="CloseForegroundBrush" Color="#DDDDDD"/>
    <SolidColorBrush x:Key="ScrollBarBackgroundBrush" Color="#2B2B2B"/>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#555555"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
    <!-- Filled highlight behind the selected emoji, like the Windows 10 panel
         (accent blended ~35% over the dark background) -->
    <SolidColorBrush x:Key="SelectionBrush" Color="#1C4666"/>

</ResourceDictionary>
