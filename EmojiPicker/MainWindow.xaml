<Window x:Class="EmojiPicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:EmojiPicker"
        Title="Classic Emoji Picker v0.1.1"
        Height="400" 
        Width="500"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Auto"
        UseLayoutRounding="False">
    
    <Window.Resources>        <!-- Emoji Font -->
        <FontFamily x:Key="EmojiFont">Segoe UI Emoji</FontFamily>
        
        <!-- Colour Emoji Text Rendering -->
        <Style x:Key="ColourEmojiText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource EmojiFont}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality"/>
        </Style>        <!-- Tab Button Style -->
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Image local:EmojiImage.Source="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Content}"
                                   Width="20" Height="20"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5E5E5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Selected Tab Style -->
        <Style x:Key="SelectedTabStyle" TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
            <Setter Property="BorderBrush" Value="#0078D4"/>
        </Style>        <!-- Emoji Button Style -->
        <Style x:Key="EmojiButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Image local:EmojiImage.Source="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Content}"
                                   Width="32" Height="32"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5E5E5"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <!-- Drag handle background (invisible but captures mouse events) -->
        <Rectangle Fill="Transparent" 
                   MouseLeftButtonDown="DragHandle_MouseLeftButtonDown"/>
        
        <!-- Main container with rounded corners and shadow -->
        <Border Background="White" 
                CornerRadius="8" 
                BorderBrush="#E1E1E1" 
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Black" Direction="315" ShadowDepth="3" Opacity="0.3" BlurRadius="5"/>
            </Border.Effect>
            
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Search Box -->
                <TextBox x:Name="SearchBox"
                         Grid.Row="0"
                         Margin="10,10,10,5"
                         Padding="8"
                         FontSize="12"
                         Text="Keep typing to find an emoji"
                         Foreground="Gray"
                         BorderBrush="#E1E1E1"
                         BorderThickness="1"
                         GotFocus="SearchBox_GotFocus"
                         LostFocus="SearchBox_LostFocus"
                         TextChanged="SearchBox_TextChanged"/>
                
                <!-- Emoji Grid -->
                <ScrollViewer Grid.Row="1" 
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="Transparent"
                              Margin="5,5,5,10">
                    <ItemsControl x:Name="EmojiGrid">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Character}" 
                                        Style="{StaticResource EmojiButtonStyle}"
                                        Click="EmojiButton_Click"
                                        ToolTip="{Binding Name}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                  <!-- Category Tabs at Bottom -->
                <StackPanel Grid.Row="2" 
                            Orientation="Horizontal" 
                            Background="#F8F8F8"
                            Height="45"
                            HorizontalAlignment="Stretch">
                    <Button x:Name="RecentTab" 
                            Content="🕒" 
                            Style="{StaticResource TabButtonStyle}"
                            Click="CategoryTab_Click"
                            Tag="Recent"
                            ToolTip="Recent"/>
                    <Button x:Name="SmileysTab" 
                            Content="😊" 
                            Style="{StaticResource SelectedTabStyle}"
                            Click="CategoryTab_Click"
                            Tag="Smileys"
                            ToolTip="Smileys &amp; Emotion"/>
                    <Button x:Name="PeopleTab" 
                            Content="👨" 
                            Style="{StaticResource TabButtonStyle}"
                            Click="CategoryTab_Click"
                            Tag="People"
                            ToolTip="People &amp; Body"/>
                    <Button x:Name="ObjectsTab" 
                            Content="🎧" 
                            Style="{StaticResource TabButtonStyle}"
                            Click="CategoryTab_Click"
                            Tag="Objects"
                            ToolTip="Objects"/>
                </StackPanel>
            </Grid>
        </Border>
          <!-- Close Button (top-right corner) -->
        <Button HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,8,8,0"
                Width="20"
                Height="20"
                Content="×"
                FontSize="14"
                FontFamily="Segoe UI"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="CloseButton_Click"
                Cursor="Hand"/>
    </Grid>
</Window>